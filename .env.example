# Database — Neon Postgres in production, SQLite for local dev
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=sqlite:///deals.db

# Reddit — include your email so Reddit can contact you if needed
REDDIT_USER_AGENT=deal-scanner/0.1 (contact: you@example.com)
# reddit.com/prefs/apps -> create app -> type: script. Without these, requests
# run anonymously (lower rate limits, more likely to get throttled/blocked).
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Worker
SUBREDDITS=buildapcsales,GameDeals,AppleDeals,PS5Deals,SwitchDeals,tradingcards,photomarket
FETCH_LIMIT=100
LOG_LEVEL=INFO

# Deals older than this are skipped on ingest and hidden from the API/site.
# Used by both worker.py and api.py.
MAX_DEAL_AGE_DAYS=30

# API (Render) — comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# social_post.py — only needed for the platform(s) you actually use.
# The script skips (logs a warning for) any platform whose vars aren't set.

# X (Twitter) — developer.x.com -> create a Project + App -> User
# authentication settings: enable OAuth 1.0a, permissions "Read and write"
# -> Keys and tokens tab -> generate an Access Token & Secret for yourself,
# in addition to the app's API Key/Secret.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Instagram — developers.facebook.com -> create a Meta app (type: Business)
# -> add the "Instagram" product. Requires your IG account to be a
# Business/Creator account linked to a Facebook Page. Generate a long-lived
# access token with instagram_basic + instagram_content_publish +
# pages_show_list scopes, then find IG_USER_ID via
# GET /me/accounts -> {page-id}?fields=instagram_business_account.
IG_USER_ID=
IG_ACCESS_TOKEN=

# Threads — same Meta app as Instagram -> add the "Threads" product -> run
# the Threads API's token flow (threads_basic + threads_content_publish
# scopes) to get THREADS_ACCESS_TOKEN; THREADS_USER_ID comes back from that
# flow's GET /me call.
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=
